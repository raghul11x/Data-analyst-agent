# Rename this file to .env and fill in your key
OPENROUTER_API_KEY=sk-or-put-your-key-here

# Model options (free tier on OpenRouter) — best to worst instruction-following:
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free      ← default, recommended
# OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free  ← avoid, ignores instructions
